{
  "expo": {
    "name": "sehar",
    "slug": "sehar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/sehar_text_icon_1764625584428.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.test1.sehar"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/sehar_text_icon_1764625584428.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.test1.sehar"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": false,
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for AI conversations"
        }
      ],
      [
        "@livekit/react-native-expo-plugin"
      ]
    ],
    "extra": {
      "APPWRITE_ENDPOINT": "https://tor.cloud.appwrite.io/v1",
      "APPWRITE_PROJECT": "69296eb80009f1d5c2e2",
      "APP_PLATFORM": "com.sehar",
      "eas": {
        "projectId": "5c78088b-73e8-43aa-83c9-5c795c8f62b1"
      }
    }
  }
}